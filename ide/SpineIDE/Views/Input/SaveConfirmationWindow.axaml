<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SpineIDE.Views.Input.SaveConfirmationWindow"
        Title="Unsaved Changes"
        Width="380"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="Auto,Auto" Margin="14">
        <TextBlock Name="MessageTextBlock"
                   TextWrapping="Wrap"
                   Margin="0,0,0,14" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel" Click="OnCancelClicked" />
            <Button Content="Discard" Click="OnDiscardClicked" />
            <Button Content="Save" Click="OnSaveClicked" />
        </StackPanel>
    </Grid>
</Window>