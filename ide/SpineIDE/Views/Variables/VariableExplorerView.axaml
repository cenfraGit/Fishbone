<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:panels="clr-namespace:SpineIDE.Panels"
             x:Class="SpineIDE.Views.Variables.VariableExplorerView"
             x:DataType="panels:VariableExplorerVM">
    <Grid RowDefinitions="Auto,*">
        <Grid ColumnDefinitions="2*,*,3*" Background="{DynamicResource PanelHeaderBrush}" Height="28">
            <TextBlock Grid.Column="0" Text="Name" Margin="8,5" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Type" Margin="8,5" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Value" Margin="8,5" FontWeight="SemiBold" />
        </Grid>
        <TreeView Grid.Row="1" ItemsSource="{Binding Variables}"
                  Background="{DynamicResource CodeSurfaceBrush}"
                  Foreground="{DynamicResource CodeSurfaceForegroundBrush}">
            <TreeView.Styles>
                <Style Selector="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
                </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
                <TreeDataTemplate DataType="panels:VariableItem" ItemsSource="{Binding Children}">
                    <!-- expand/collapse uses the TreeView's native chevron; rows are vertically centered -->
                    <Grid ColumnDefinitions="2*,*,3*" MinHeight="22">
                        <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="4,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Type}" Margin="4,0" VerticalAlignment="Center" Foreground="{DynamicResource VariableTypeBrush}" />
                        <TextBlock Grid.Column="2" Text="{Binding ValueDisplay}" Margin="4,0" VerticalAlignment="Center" Foreground="{DynamicResource VariableValueBrush}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>