                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Button>-->

        </DockPanel>

        <dock:DockControl DockPanel.Dock="Top" Layout="{Binding Layout}" />

    </DockPanel>

</Window>