<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SpineIDE.Views.Attach.RemoteAttachWindow"
        Title="Attach to Remote Fishbone"
        Width="390" Height="190"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="12" ColumnSpacing="12">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Host" VerticalAlignment="Center" />
        <TextBox x:Name="HostBox" Grid.Row="0" Grid.Column="1" Text="127.0.0.1" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Port" VerticalAlignment="Center" />
        <NumericUpDown x:Name="PortBox" Grid.Row="1" Grid.Column="1"
                       Minimum="1" Maximum="65535" Value="4711" FormatString="0" />
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button Content="Cancel" Click="OnCancel" />
            <Button Content="Attach" Click="OnAttach" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>