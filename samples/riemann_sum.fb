func f(x)
{
    return x * x;
}

let a = 0; // lower limit
let b = 3; // upper limit
let n = 100;

let dx = (b - a) / n;

let riemann_sum = 0;

let i = 0;
while (i < n)
{
    let x = a + i * dx;
    riemann_sum = riemann_sum + f(x) * dx;
    i = i + 1;
}

println("Approx integral is " + riemann_sum);